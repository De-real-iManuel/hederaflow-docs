{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Hedera Flow Docs",
  "colors": {
    "primary": "#0066FF",
    "light": "#3399FF",
    "dark": "#0052CC"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "overview",
              "tech-stack",
              "architecture"
            ]
          },
          {
            "group": "Getting Started",
            "pages": [
              "getting-started",
              "mvp-features"
            ]
          },
          {
            "group": "Advanced",
            "pages": [
              "engineering-notes",
              "roadmap"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "API documentation",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Endpoint examples",
            "pages": [
              "api-reference/endpoint/get",
              "api-reference/endpoint/create",
              "api-reference/endpoint/delete",
              "api-reference/endpoint/webhook"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/yourusername/hedera-flow",
          "icon": "github"
        },
        {
          "anchor": "HashScan",
          "href": "https://hashscan.io/testnet",
          "icon": "cube"
        },
        {
          "anchor": "Hedera",
          "href": "https://hedera.com",
          "icon": "link"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Demo",
        "href": "https://hedera-flow.vercel.app"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get Started",
      "href": "/getting-started"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/yourusername/hedera-flow",
      "x": "https://x.com/hederaflow"
    }
  }
}
